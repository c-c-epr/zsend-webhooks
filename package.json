{
  "name": "zsend-webhooks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prestart": "wrangler types",
    "start": "wrangler dev -e .env",
    "predev": "wrangler types",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "test:run": "vitest run",
    "cf-typegen": "wrangler types",
    "types": "wrangler types",
    "types:sync": "wrangler types",
    "types:check": "pnpm run types:sync && git diff --exit-code -- worker-configuration.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@types/node": "^25.6.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "packageManager": "pnpm@11.0.9"
}
