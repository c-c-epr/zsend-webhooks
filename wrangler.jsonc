{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zsend-webhooks",
  "main": "src/_index.ts",
  "compatibility_date": "2026-04-27",
  "secrets": {
    "required": ["SECRET_KEY"],
  },
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"],
  "placement": { "mode": "smart" },
}
